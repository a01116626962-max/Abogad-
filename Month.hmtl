<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم الإدارية | مزامنة الجداول</title>
    <style>
        :root {
            --bg-dark: #121826;
            --surface-dark: #1f2937;
            --primary: #3b82f6;
            --primary-hover: #2563eb;
            --success: #10b981;
            --warning: #f59e0b;
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --border: #374151;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', system-ui, sans-serif; }

        body { background-color: var(--bg-dark); color: var(--text-main); padding: 30px; }

        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .dashboard-header h1 { font-size: 1.8em; font-weight: 600; display: flex; align-items: center; gap: 10px; }
        .cycle-badge { background: rgba(59, 130, 246, 0.1); color: var(--primary); padding: 8px 15px; border-radius: 20px; font-size: 0.9em; border: 1px solid var(--primary); }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background-color: var(--surface-dark);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); border-color: #4b5563; }

        .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .card-title { font-size: 1.1em; font-weight: bold; color: #fff; }
        
        .status-dot {
            height: 10px; width: 10px; border-radius: 50%; display: inline-block;
        }
        .status-active { background-color: var(--success); box-shadow: 0 0 8px var(--success); }
        .status-inactive { background-color: var(--text-muted); }

        .days-container { display: flex; flex-wrap: wrap; gap: 8px; }
        .day-badge {
            background-color: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            color: var(--text-muted);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.85em;
        }
        .day-badge.active { background-color: rgba(59, 130, 246, 0.15); color: var(--primary); border-color: var(--primary); }

        .controls { display: flex; gap: 15px; margin-bottom: 30px; }

        .btn-sync {
            background-color: var(--primary);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 8px;
            font-size: 1.1em;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
            flex: 1;
            justify-content: center;
        }
        .btn-sync:hover { background-color: var(--primary-hover); }
        .btn-sync:disabled { background-color: var(--border); color: var(--text-muted); cursor: not-allowed; }

        .terminal {
            background-color: #000;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 20px;
            font-family: 'Consolas', monospace;
            font-size: 0.9em;
            height: 250px;
            overflow-y: auto;
            color: #a3be8c;
        }
        .terminal-row { margin-bottom: 5px; line-height: 1.4; }
        .term-info { color: #81a1c1; }
        .term-success { color: #a3be8c; }
        .term-warning { color: #ebcb8b; }
        .term-error { color: #bf616a; }

        /* التمرير المخصص للـ Terminal */
        .terminal::-webkit-scrollbar { width: 8px; }
        .terminal::-webkit-scrollbar-track { background: #000; }
        .terminal::-webkit-scrollbar-thumb { background: #4c566a; border-radius: 4px; }
    </style>
</head>
<body>

    <div class="dashboard-header">
        <h1>⚙️ نظام الجدولة الذكي</h1>
        <div class="cycle-badge" id="cycle-badge">جاري حساب الدورة...</div>
    </div>

    <div class="grid-container" id="volunteers-grid">
        </div>

    <div class="controls">
        <button id="sync-btn" class="btn-sync" onclick="executeSync()">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            تنفيذ المزامنة (تخطي المسجل مسبقاً)
        </button>
    </div>

    <div class="terminal" id="terminal">
        <div class="terminal-row term-info">>> النظام جاهز. في انتظار أمر المزامنة...</div>
    </div>

<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-firestore.js"></script>

<script>
    // إعدادات Firebase
    const firebaseConfig = {
        apiKey: "AIzaSyCDJANXMfd6TR7R2ruLIi-xytlrB-LiCEs",
        authDomain: "rdtt-15cbe.firebaseapp.com",
        projectId: "rdtt-15cbe",
        storageBucket: "rdtt-15cbe.firebasestorage.app",
        messagingSenderId: "219502671343",
        appId: "1:219502671343:web:b289b11869e25c9a30321a"
    };
    if (!firebase.apps.length) { firebase.initializeApp(firebaseConfig); }
    const db = firebase.firestore();

    // البيانات الأساسية
    const WORKING_DAYS = ["السبت", "الأحد", "الإثنين", "الثلاثاء", "الأربعاء", "الخميس"];
    
    const FIXED_VOLUNTEERS = {
        "شيماء":            WORKING_DAYS,
        "حبيبة":            WORKING_DAYS,
        "رحاب":             ["السبت", "الأحد", "الثلاثاء"],
        "أحمد":             WORKING_DAYS,
        "محمد إبراهيم":     WORKING_DAYS,
        "ساندي":            ["السبت", "الأحد", "الأربعاء", "الخميس"],
        "إبراهيم":          [],
        "معاذ":             ["الأحد", "الثلاثاء", "الخميس"],
        "سامى":             ["السبت", "الأحد"],
        "مازن":             WORKING_DAYS,
        "معتز":             WORKING_DAYS,
        "شمس":              WORKING_DAYS
    };

    const JS_DAY_MAP = { 0: "الأحد", 1: "الإثنين", 2: "الثلاثاء", 3: "الأربعاء", 4: "الخميس", 5: "الجمعة", 6: "السبت" };

    // أدوات الواجهة (Terminal & UI)
    const terminal = document.getElementById('terminal');
    function logToTerminal(msg, type = 'term-info') {
        const row = document.createElement('div');
        row.className = `terminal-row ${type}`;
        row.textContent = `[${new Date().toLocaleTimeString('ar-EG')}] ${msg}`;
        terminal.appendChild(row);
        terminal.scrollTop = terminal.scrollHeight;
    }

    // حساب الدورة (26 - 25)
    function getCycleDates() {
        const now = new Date();
        let start, end;
        if (now.getDate() >= 26) {
            start = new Date(now.getFullYear(), now.getMonth(), 26);
            end = new Date(now.getFullYear(), now.getMonth() + 1, 25);
        } else {
            start = new Date(now.getFullYear(), now.getMonth() - 1, 26);
            end = new Date(now.getFullYear(), now.getMonth(), 25);
        }
        return { start, end };
    }

    // تهيئة الواجهة
    function initUI() {
        const { start, end } = getCycleDates();
        document.getElementById('cycle-badge').textContent = `دورة: ${start.toLocaleDateString('en-GB')} » ${end.toLocaleDateString('en-GB')}`;

        const grid = document.getElementById('volunteers-grid');
        for (const [name, schedule] of Object.entries(FIXED_VOLUNTEERS)) {
            const isActive = schedule.length > 0;
            let daysHtml = '';
            
            WORKING_DAYS.forEach(day => {
                const isScheduled = schedule.includes(day);
                daysHtml += `<span class="day-badge ${isScheduled ? 'active' : ''}">${day}</span>`;
            });

            grid.innerHTML += `
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">${name}</span>
                        <span class="status-dot ${isActive ? 'status-active' : 'status-inactive'}"></span>
                    </div>
                    <div class="days-container">
                        ${isActive ? daysHtml : '<span class="day-badge" style="color:#ef4444; border-color:#ef4444;">غير مجدول (إجازة)</span>'}
                    </div>
                </div>
            `;
        }
    }

    // المزامنة الذكية
    async function executeSync() {
        if (!confirm("تأكيد إرسال المواعيد للدورة الحالية؟ (لن يتم مسح أي بيانات سابقة)")) return;

        const btn = document.getElementById('sync-btn');
        btn.disabled = true;
        btn.innerHTML = 'جاري المعالجة... ⏳';
        
        const { start, end } = getCycleDates();
        logToTerminal(`بدء فحص الدورة من ${start.toISOString().split('T')[0]} إلى ${end.toISOString().split('T')[0]}`, 'term-warning');

        try {
            const startKey = start.toISOString().split('T')[0];
            const endKey = end.toISOString().split('T')[0];
            
            // جلب البيانات الموجودة لتجنب الكتابة فوقها
            const snapshot = await db.collection("user_attendance")
                .where("dateKey", ">=", startKey)
                .where("dateKey", "<=", endKey)
                .get();

            const existingDocs = new Set();
            snapshot.forEach(doc => existingDocs.add(doc.id));
            logToTerminal(`تم العثور على ${existingDocs.size} سجلات سابقة. سيتم تخطيها.`, 'term-info');

            let batch = db.batch();
            let opCount = 0;
            let addedCount = 0;
            let skippedCount = 0;

            let currentDate = new Date(start);
            while (currentDate <= end) {
                const dayName = JS_DAY_MAP[currentDate.getDay()];
                const dateKey = currentDate.toISOString().split('T')[0];

                for (const [name, scheduledDays] of Object.entries(FIXED_VOLUNTEERS)) {
                    if (scheduledDays.includes(dayName)) {
                        const docId = `${name}_${dateKey}`;
                        
                        if (existingDocs.has(docId)) {
                            skippedCount++;
                        } else {
                            const docRef = db.collection("user_attendance").doc(docId);
                            batch.set(docRef, {
                                volunteerName: name,
                                status: "حضور (تلقائي)",
                                reason: "لم يسجل (مجدول)", // كما طلبت في الرسالة الأولى
                                dateKey: dateKey,
                                registrationTime: `${dayName} (${currentDate.getDate()}/${currentDate.getMonth()+1}) – 00:00 ص`,
                                timestamp: firebase.firestore.FieldValue.serverTimestamp(),
                                isAutoGenerated: true
                            });
                            opCount++;
                            addedCount++;
                        }

                        // تنفيذ الـ Batch إذا وصل 400
                        if (opCount >= 400) {
                            await batch.commit();
                            batch = db.batch();
                            opCount = 0;
                            logToTerminal(`تم رفع حزمة بيانات للـ Server...`, 'term-info');
                        }
                    }
                }
                currentDate.setDate(currentDate.getDate() + 1);
            }

            if (opCount > 0) {
                await batch.commit();
            }

            logToTerminal(`✅ العملية تمت بنجاح!`, 'term-success');
            logToTerminal(`+ تمت إضافة: ${addedCount} سجل جديد.`, 'term-success');
            logToTerminal(`- تم تخطي: ${skippedCount} سجل موجود مسبقاً.`, 'term-warning');

        } catch (error) {
            logToTerminal(`❌ خطأ في النظام: ${error.message}`, 'term-error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = `<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg> تنفيذ المزامنة (تخطي المسجل مسبقاً)`;
        }
    }

    // تشغيل عند التحميل
    window.onload = initUI;
</script>

</body>
</html>
